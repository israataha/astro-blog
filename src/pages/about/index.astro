---
import PageLayout from "@/layouts/PageLayout.astro";
import TopLayout from "@/layouts/TopLayout.astro";
import BottomLayout from "@/layouts/BottomLayout.astro";
import { ABOUT } from "@/consts";
---

<PageLayout title={ABOUT.TITLE} description={ABOUT.DESCRIPTION}>
  <TopLayout>
    <div class="animate page-heading">
      {ABOUT.TITLE}
    </div>
  </TopLayout>

  <BottomLayout>
    <!-- <div class="animate"></div> -->
    <div class="relative bg-white dark:bg-black">
      <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16">
        <!-- About Section -->
        <section class="animate">
          <article>
            <p>
              I am a <b><i>mobile developer</i></b>, <b><i>conference speaker</i></b>, <b><i>writer</i></b> and <b
                ><i>avid baker</i></b
              >. I build cross-platform apps with React Native and Expo, with a focus on architecture, quality, and
              user-centric design.
            </p>
            <p>
              I care about the difference between software that works and software that feels great. That gap usually
              shows up in thoughtful architecture, intentional UX, and the polish users notice without being able to
              name it.
            </p>
            <p>
              I have over 10 years of experience building web and mobile applications. These days my focus is the React
              Native and Expo ecosystem, but I've also worked with React, TypeScript, Ionic, .NET/C#, PostgreSQL, and
              Azure, to name a few.
            </p>
            <p>
              I'm also curious about how AI fits into modern development — using it to move faster on repetitive work,
              explore ideas, and spend more time on the problems that need a human touch.
            </p>
            <p>
              When I'm not behind the computer, I'm usually spending quality time with my family, going on walks, and
              geocaching adventures with my kids. We also love watching movies and shows together; our current favorite
              is The Amazing Race. We also enjoy traveling across the US and internationally. Some of my favorite
              destinations have been Spain and Japan, both of which have left me with unforgettable memories.
            </p>
          </article>
        </section>
        <script type="text/javascript" src="https://sessionize.com/api/speaker/events/zu87io897v/1x0x3fb393x"></script>
      </div>
    </div>
  </BottomLayout></PageLayout
>
